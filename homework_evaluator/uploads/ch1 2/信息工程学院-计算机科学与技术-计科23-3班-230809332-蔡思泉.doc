 w:val="off"/><w:compat><w:breakWrappedTables/><w:useFELayout/></w:compat><wsp:rsids><wsp:rsidRoot wsp:val="005447A9"/><wsp:rsid wsp:val="001E71E7"/><wsp:rsid wsp:val="004145CF"/><wsp:rsid wsp:val="005447A9"/><wsp:rsid wsp:val="0065431B"/><wsp:rsid wsp:val="00825FB1"/><wsp:rsid wsp:val="0089642E"/><wsp:rsid wsp:val="00C524ED"/><wsp:rsid wsp:val="00CC419E"/><wsp:rsid wsp:val="00DF1FED"/></wsp:rsids></w:docPr><w:body><wx:sect><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="004145CF"><w:pPr><w:jc w:val="center"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="44"/><w:sz-cs w:val="44"/><w:lang w:val="EN-US"/></w:rPr><w:t> </w:t></w:r><w:r wsp:rsidR="001E71E7"><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="44"/><w:sz-cs w:val="44"/></w:rPr><w:t>第一章 网络安全基础</w:t></w:r><w:r wsp:rsidR="001E71E7"><w:t> </w:t></w:r></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:jc w:val="center"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/></w:rPr><w:t> </w:t></w:r></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/><w:color w:val="FF0000"/><w:sz w:val="44"/><w:sz-cs w:val="44"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:color w:val="FF0000"/></w:rPr><w:t>答题人：蔡思泉    提交时间：</w:t></w:r><w:r><w:rPr><w:color w:val="FF0000"/></w:rPr><w:t>2026-03-08 14:24:47        </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:color w:val="FF0000"/></w:rPr><w:t> 作业得分：</w:t></w:r><w:r><w:rPr><w:color w:val="FF0000"/></w:rPr><w:t> 0 </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:color w:val="FF0000"/></w:rPr><w:t>分</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:color w:val="FF0000"/><w:sz w:val="44"/><w:sz-cs w:val="44"/></w:rPr><w:t> </w:t></w:r></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:pStyle w:val="NormalWeb"/><w:jc w:val="left"/><w:rPr><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:t>1.</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/></w:rPr><w:t>《安全观察笔记》</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/></w:rPr><w:br/></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/></w:rPr><w:br/><w:t>个人作业，提交一份简短的文字报告（300-500字）。</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/></w:rPr><w:br/></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/></w:rPr><w:br/></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/></w:rPr><w:br/><w:t>回顾近年来你使用网络时遇到或想到的与“安全”相关的事情。选择其中印象最深的一件（如：收到诈骗邮件、App要求过多权限、看到某数据泄露的新闻、在公共场所使用Wi-Fi的顾虑等）。用本章学到的至少2个核心概念去描述和分析这件事。 </w:t></w:r><w:r><w:t> </w:t></w:r><w:r><w:rPr><w:color w:val="FF0000"/></w:rPr><w:t>    </w:t></w:r></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:pStyle w:val="NormalWeb"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t>学生答案： 《安全观察笔记》</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:br/><w:t>作为计算机专业的学生，我对网络安全的深刻认知，源于一次咖啡厅公共Wi-Fi的使用经历。去年寒假，我为节省流量连接了无密码公共Wi-Fi，刚输入网课平台的账号密码，就收到了学校信息中心的风险提醒，这件事让我对网络安全有了全新的理解。</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:br/><w:t> </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:br/><w:t>这件事恰好印证了数据链路层安全与多因素身份认证两个核心概念。开放无密码Wi-Fi采用明文传输，黑客可通过ARP欺骗拦截数据包，窃取用户敏感信息；而我仅用“账号+密码”的单一登录方式，违背了多因素认证原则，缺少额外验证环节，一旦信息泄露，账户便毫无安全保障。</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:br/><w:t> </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:br/><w:t>这次经历也打破了我此前的多个错误认知：我曾以为不连公共Wi-Fi就能百分百规避黑客攻击，实则钓鱼邮件、恶意软件都可能成为入侵渠道；曾以为弱密码一定会被攻破，实则多因素认证、系统补丁能大幅提升攻击门槛；也曾把设备卡顿、弹窗广告简单归因为设备老化，实则这很可能是恶意软件入侵的信号。</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:br/><w:t> </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:br/><w:t>这次经历让我明白，网络安全隐患无处不在。我们既要警惕开放网络的风险，也要养成良好的上网习惯，筑牢个人信息安全的防线。 </w:t></w:r></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:pStyle w:val="NormalWeb"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t>正确答案： </w:t></w:r><w:r><w:rPr><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t>  </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t> </w:t></w:r></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:pStyle w:val="NormalWeb"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t>教师批语：  </w:t></w:r></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:pStyle w:val="NormalWeb"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t>题目得分：</w:t></w:r><w:r><w:rPr><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t>0</w:t></w:r></w:p><w:p wsp:rsidR="00000000" wsp:rsidRDefault="00000000" wsp:rsidP="00A76A7E"><w:pPr><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/></w:rPr></w:pPr></w:p><w:p wsp:rsidR="00C524ED" wsp:rsidRDefault="001E71E7"><w:pPr><w:pStyle w:val="NormalWeb"/><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun" w:hint="fareast"/><wx:font wx:val="SimSun"/><w:sz w:val="21"/><w:sz-cs w:val="21"/></w:rPr><w:t>作业批语：</w:t></w:r></w:p><w:p wsp:rsidR="00000000" wsp:rsidRDefault="00000000" wsp:rsidP="00A76A7E"><w:pPr><w:jc w:val="left"/><w:rPr><w:rFonts w:ascii="SimSun" w:h-ansi="SimSun"/><wx:font wx:val="SimSun"/></w:rPr></w:pPr></w:p><w:sectPr wsp:rsidR="009308DC" wsp:rsidSect="00C524ED"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1276" w:right="1077" w:bottom="1440" w:left="1077" w:header="851" w:footer="992" w:gutter="0"/><w:cols w:space="425"/><w:docGrid w:type="lines" w:line-pitch="312"/></w:sectPr></wx:sect></w:body></w:wordDocument>